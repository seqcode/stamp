# MongoDB
MONGODB_URI=mongodb://localhost:27017/stamp

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Admin — IMPORTANT: Change this value before deploying to production!
# The server will reject login attempts with the default password in production mode.
ADMIN_PASSWORD=change-me-in-production

# STAMP binary
STAMP_BINARY=/usr/local/bin/stamp
SCORE_DISTS_DIR=/path/to/ScoreDists

# Job settings
JOB_TIMEOUT_MS=300000
JOB_RETENTION_DAYS=7
JOBS_DATA_DIR=/tmp/stamp-jobs

# Rate limiting
RATE_LIMIT_JOBS_PER_HOUR=20

# Email notifications via Brevo (optional)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=stamp@stamp.mahonylab.org

# Public URL (for email links)
PUBLIC_URL=http://localhost:3000
